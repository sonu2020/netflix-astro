---
import MovieSearchBar from "./MovieSearchBar.jsx";
import { Classic_malayalam_Movies } from "../data/movies";
import { Popular_Malayalam_movies } from "../data/movies";
import { Top_Tamil_Movies } from "../data/movies";
import { Top_Hindi_Movies } from "../data/movies";
import { Top_English_Movies } from "../data/movies";
import { Latest_Tamil_Movies } from "../data/movies";
import { Latest_Malayalam_Movies } from "../data/movies";

const allMovies = [
  ...Classic_malayalam_Movies,
  ...Popular_Malayalam_movies,
  ...Top_Tamil_Movies,
  ...Top_Hindi_Movies,
  ...Top_English_Movies,
  ...Latest_Tamil_Movies,
  ...Latest_Malayalam_Movies,
];
---

<div class="navbar">
  <img class="logo-img" src="/thumbnails/malluflixlog.png" />
  <MovieSearchBar movies={allMovies} client:load />
</div>
