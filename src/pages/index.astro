---
import "../styles/global.css";

import Header from "../components/Header.astro";
import MovieCard from "../components/MovieCard.astro";
import Footer from "../components/Footer.astro";
import { Classic_malayalam_Movies } from "../data/movies";
import { Popular_Malayalam_movies } from "../data/movies";
import { Top_Tamil_Movies } from "../data/movies";
import { Top_Hindi_Movies } from "../data/movies";
import { Top_English_Movies } from "../data/movies";
import { Latest_Tamil_Movies } from "../data/movies";
import { Latest_Malayalam_Movies } from "../data/movies";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>MalluFlix</title>
  </head>
  <Header />

  <h1 class="title">Classic Malayalam Movies &#xBB;</h1>
  <div class="movie-card">
    {
      Classic_malayalam_Movies.map((movie) => (
        <MovieCard
          image={movie.image}
          title={movie.title}
          year={movie.year}
          link={movie.link}
        />
      ))
    }
  </div>
  <h1 class="title">Popular Malayalam movies &#xBB;</h1>

  <div class="movie-card">
    {
      Popular_Malayalam_movies.map((movie) => (
        <MovieCard
          image={movie.image}
          title={movie.title}
          year={movie.year}
          link={movie.link}
        />
      ))
    }
  </div>
  <h1 class="title">Top Tamil Movies &#xBB;</h1>

  <div class="movie-card">
    {
      Top_Tamil_Movies.map((movie) => (
        <MovieCard
          image={movie.image}
          title={movie.title}
          year={movie.year}
          link={movie.link}
        />
      ))
    }
  </div>
  <h1 class="title">Top Hindi Movies &#xBB;</h1>

  <div class="movie-card">
    {
      Top_Hindi_Movies.map((movie) => (
        <MovieCard
          image={movie.image}
          title={movie.title}
          year={movie.year}
          link={movie.link}
        />
      ))
    }
  </div>
  <h1 class="title">Top English Movies &#xBB;</h1>

  <div class="movie-card">
    {
      Top_English_Movies.map((movie) => (
        <MovieCard
          image={movie.image}
          title={movie.title}
          year={movie.year}
          link={movie.link}
        />
      ))
    }
  </div>
  <h1 class="title">Latest Tamil Movies &#xBB;</h1>

  <div class="movie-card">
    {
      Latest_Tamil_Movies.map((movie) => (
        <MovieCard
          image={movie.image}
          title={movie.title}
          year={movie.year}
          link={movie.link}
        />
      ))
    }
  </div>
  <h1 class="title">Latest Malayalam Movies &#xBB;</h1>

  <div class="movie-card">
    {
      Latest_Malayalam_Movies.map((movie) => (
        <MovieCard
          image={movie.image}
          title={movie.title}
          year={movie.year}
          link={movie.link}
        />
      ))
    }
  </div>


  <Footer />
</html>
